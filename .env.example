# ── Supabase ──────────────────────────────────────────────────
# Next.js (클라이언트 노출 가능 — anon key만)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Route Handlers (서버 전용 — service key 절대 클라이언트에 노출 금지)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Python 수집기 (GitHub Actions Secrets + pooler URL)
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ── Cloudflare 환경변수 (Dashboard에서 설정) ─────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID
GITHUB_PAT=ghp_...          # Actions: write 권한 필요 (workflow_dispatch용)
GITHUB_REPO=owner/repo-name

# ── DART API ─────────────────────────────────────────────────
DART_API_KEY=YOUR_DART_API_KEY
